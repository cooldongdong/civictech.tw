---
const videoSrc = `${import.meta.env.BASE_URL}videos/hero-background.mp4`; // 預計放在 public/videos/ 下
const posterSrc = `${import.meta.env.BASE_URL}images/hero-poster.png`;     // 手機端或未載入前的替代靜態圖
const title = "台灣公民科技資料庫";
const subtitle = "探索、協作、自主開源，連結數位公民的實踐指南";
---

<section class="hero-container">
  <div class="video-wrapper">
    <video 
      autoplay 
      loop 
      muted 
      playsinline 
      poster={posterSrc}
      class="bg-video"
    >
      <source src={videoSrc} type="video/mp4" />
      您的瀏覽器不支援 HTML5 影片播放。
    </video>
    <div class="video-overlay"></div>
  </div>

  <div class="hero-content">
    <h1>{title}</h1>
    <p>{subtitle}</p>
    <a href="#know-how" class="cta-button">
      探索 40 則關鍵 Know-how
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
    </a>
  </div>
</section>

<style>
  /* 滿版容器設定 */
  .hero-container {
    position: relative;
    width: 100%;
    height: 100vh; /* 佔滿整個螢幕高度 */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }

  /* 影片包覆層：絕對定位並撐滿 */
  .video-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  /* 影片本身：滿版、不變形、置中 */
  .bg-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* 半透明遮罩 */
  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.45); /* 45% 的黑色遮罩，可依影片明暗調整 */
  }

  /* 前景內容層 */
  .hero-content {
    position: relative;
    z-index: 2; /* 確保在影片與遮罩上方 */
    text-align: center;
    color: #ffffff;
    padding: 0 20px;
    max-width: 800px;
  }

  .hero-content h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: 2px;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-content p {
    font-size: 1.25rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }

  /* 按鈕樣式 */
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #0284c7; /* 天藍色系，可依視覺規範調整 */
    color: #ffffff;
    text-decoration: none;
    padding: 12px 28px;
    border-radius: 9999px;
    font-size: 1.1rem;
    font-weight: 500;
    transition: all 0.2s ease-in-out;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .cta-button:hover {
    background-color: #0369a1;
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .arrow-icon {
    animation: bounce 2s infinite;
  }

  /* 按鈕內箭頭微動效 */
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(4px); }
    60% { transform: translateY(2px); }
  }

  /* 針對手機端的響應式調整 */
  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2rem;
    }
    .hero-content p {
      font-size: 1rem;
    }
    .cta-button {
      padding: 10px 22px;
      font-size: 1rem;
    }
  }
</style>